module voxel_renderer_backup @if(false);

import donut;
import xray;
import std::io;
import std::math;

struct Vec3 {
    float x;
    float y;
    float z;
}

struct Voxel {
    Vec3 pos;
}

struct VoxelModel {
    Voxel[8192] voxels;
    int voxel_count;
    float rotation_x;
    float rotation_y;
    float rotation_z;
    int width;
    int height;
    int frame;
    xray::Cell[] cells;
    float[] depth;
}

fn Vec3 vec3(float x, float y, float z) => (Vec3) { x, y, z };

fn Vec3 Vec3.rotate_x(&self, float angle) {
    float c = (float)math::cos(angle);
    float s = (float)math::sin(angle);
    return vec3(self.x, self.y * c - self.z * s, self.y * s + self.z * c);
}

fn Vec3 Vec3.rotate_y(&self, float angle) {
    float c = (float)math::cos(angle);
    float s = (float)math::sin(angle);
    return vec3(self.x * c + self.z * s, self.y, -self.x * s + self.z * c);
}

fn Vec3 Vec3.rotate_z(&self, float angle) {
    float c = (float)math::cos(angle);
    float s = (float)math::sin(angle);
    return vec3(self.x * c - self.y * s, self.x * s + self.y * c, self.z);
}

const int GRID_W = 25;
const int GRID_H = 5;

const String[5] ROWS = {
    "████████ ███████  █████  ",
    "   ██    ██      ██   ██ ",
    "   ██    █████   ███████ ",
    "   ██    ██      ██   ██ ",
    "   ██    ███████ ██   ██ ",
};

fn bool grid_set(int x, int y) {
    if (x < 0 || x >= GRID_W || y < 0 || y >= GRID_H) return false;
    String row = ROWS[y];
    int col = 0;
    sz i = 0;
    while (i < row.len && col <= x) {
        char b = row[i];
        if (b == ' ') {
            if (col == x) return false;
            col++;
            i++;
        } else {
            if (col == x) return true;
            col++;
            i += 3;
        }
    }
    return false;
}

fn donut::Cmd VoxelModel.init(VoxelModel* self) @dynamic {
    self.width = 80;
    self.height = 24;
    self.frame = 0;
    self.voxel_count = 0;
    self.cells = mem::new_array(xray::Cell, (sz)(self.width * self.height));
    self.depth = mem::new_array(float, (sz)(self.width * self.height));
    create_voxels(self);
    donut::Cmd[] cmds = { donut::tick() };
    return donut::batch(cmds);
}

fn void create_voxels(VoxelModel* self) {
    float offset_x = -(float)GRID_W / 2.0f;
    float offset_y = -(float)GRID_H / 2.0f;

    for (int gy = 0; gy < GRID_H; gy++) {
        for (int gx = 0; gx < GRID_W; gx++) {
            if (!grid_set(gx, gy)) continue;
            for (int gz = 0; gz < 3; gz++) {
                if (self.voxel_count >= 8192) return;
                self.voxels[self.voxel_count++] = {
                    .pos = vec3(
                        (float)gx + offset_x,
                        -(float)gy - offset_y,
                        (float)gz - 1.0f
                    ),
                };
            }
        }
    }
}

fn donut::Cmd VoxelModel.update(VoxelModel* self, donut::Msg msg) @dynamic {
    if (msg.kind == donut::MsgKind.WINDOW_SIZE) {
        self.width = msg.window_size.width;
        self.height = msg.window_size.height;
        mem::free(self.cells.ptr);
        mem::free(self.depth.ptr);
        self.cells = mem::new_array(xray::Cell, (sz)(self.width * self.height));
        self.depth = mem::new_array(float, (sz)(self.width * self.height));
        return null;
    }

    if (msg.kind == donut::MsgKind.TICK) {
        self.frame++;
        self.rotation_x = (float)math::sin((float)self.frame * 0.003) * 0.15f;
        self.rotation_y = (float)self.frame * 0.01f;
        self.rotation_z = 0.0f;
        return donut::tick();
    }

    if (msg.kind != donut::MsgKind.KEY) return null;
    donut::KeyMsg k = msg.key;
    switch (k.code) {
        case donut::KeyCode.CTRL_C:
            return donut::quit();
        case donut::KeyCode.RUNE:
            if (k.rune == 'q') return donut::quit();
        default:
    }
    return null;
}

fn donut::View VoxelModel.view(VoxelModel* self) @dynamic {
    int w = self.width;
    int h = self.height;
    sz total = (sz)(w * h);

    for (sz i = 0; i < total; i++) {
        self.cells[i] = xray::empty_cell();
        self.depth[i] = 1000.0f;
    }

    float fov  = 30.0f;
    float dist = 20.0f;
    float cx   = (float)w / 2.0f;
    float cy   = (float)h / 2.0f;

    // light direction (world space, normalized)
    float light_x =  0.4f;
    float light_y =  0.8f;
    float light_z = -0.5f;
    float light_len = (float)math::sqrt(light_x*light_x + light_y*light_y + light_z*light_z);
    light_x /= light_len;
    light_y /= light_len;
    light_z /= light_len;

    for (int v = 0; v < self.voxel_count; v++) {
        Vec3 p = self.voxels[v].pos;

        p = p.rotate_x(self.rotation_x);
        p = p.rotate_y(self.rotation_y);
        p = p.rotate_z(self.rotation_z);

        float dz = dist + p.z;
        if (dz < 0.1f) continue;

        float scale = fov / dz;
        float sx = p.x * scale * 2.0f + cx;
        float sy = -p.y * scale + cy;

        float hs_x = scale * 2.0f * 0.49f;
        float hs_y = scale * 0.49f;

        int x0 = (int)(sx - hs_x);
        int x1 = (int)(sx + hs_x);
        int y0 = (int)(sy - hs_y);
        int y1 = (int)(sy + hs_y);

        // simple diffuse: use voxel position as a proxy for face normal
        float brightness = p.x * light_x + p.y * light_y + p.z * light_z;
        brightness = brightness * 0.4f + 0.6f;
        if (brightness < 0.2f) brightness = 0.2f;
        if (brightness > 1.0f) brightness = 1.0f;

        char r = (char)(brightness * 220.0f);
        char g = (char)(brightness * 180.0f);
        char b = (char)(brightness * 255.0f);
        xray::Style style = xray::default_style().set_fg(xray::color_rgb(r, g, b));

        for (int py = y0; py <= y1; py++) {
            if (py < 0 || py >= h) continue;
            for (int px = x0; px <= x1; px++) {
                if (px < 0 || px >= w) continue;
                sz idx = (sz)(py * w + px);
                if (p.z < self.depth[idx]) {
                    self.depth[idx] = p.z;
                    self.cells[idx] = xray::new_cell("\xe2\x96\x88", 1, style);
                }
            }
        }
    }

    // post-process AA: for each empty pixel, sum contributions from filled neighbours.
    // gaps between letters get contributions from both sides = brighter fringe.
    // outer silhouette gets contribution from only one side = dimmer fringe.
    int[4] dx = { 1, -1, 0,  0 };
    int[4] dy = { 0,  0, 1, -1 };
    for (int py = 0; py < h; py++) {
        for (int px = 0; px < w; px++) {
            sz idx = (sz)(py * w + px);
            if (self.depth[idx] < 999.0f) continue; // filled, skip

            float sum_r = 0.0f;
            float sum_g = 0.0f;
            float sum_b = 0.0f;
            int count = 0;

            for (int d = 0; d < 4; d++) {
                int nx = px + dx[d];
                int ny = py + dy[d];
                if (nx < 0 || nx >= w || ny < 0 || ny >= h) continue;
                sz nidx = (sz)(ny * w + nx);
                if (self.depth[nidx] >= 999.0f) continue;
                xray::Cell src = self.cells[nidx];
                sum_r += (float)src.style.fg.r;
                sum_g += (float)src.style.fg.g;
                sum_b += (float)src.style.fg.b;
                count++;
            }

            if (count == 0) continue;

            float scale = (float)count * 0.20f;
            char r = (char)(sum_r / (float)count * scale);
            char g = (char)(sum_g / (float)count * scale);
            char b = (char)(sum_b / (float)count * scale);
            xray::Style aa_style = xray::default_style().set_fg(xray::color_rgb(r, g, b));
            self.cells[idx] = xray::new_cell("\xe2\x96\x88", 1, aa_style);
        }
    }

    return donut::new_alt_cell_view(self.cells, (sz)w, (sz)h);
}

fn int main() {
    VoxelModel* model = mem::new(VoxelModel);
    if (catch err = donut::@run_program(model)) {
        io::printfn("Error: %s", err);
        return 1;
    }
    mem::free(model);
    return 0;
}
